{
  "name": "Portfolio-Dev-Container",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:latest",
  
  "customizations": {
    "vscode": {
      "settings": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true
      },
      "extensions": [
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint",
        "bradlc.vscode-tailwindcss",
        "astro-build.astro-vscode",
        "dsznajder.es7-react-js-snippets"
      ]
    }
  },

  "forwardPorts": [12233, 3000, 4321],
  "mounts": [
        "source=${localWorkspaceFolder}/container-vscode,target=/root,type=bind"
    ],
  "portsAttributes": {
    "12233": {
      "label": "Custom Forward Port",
      "onAutoForward": "notify"
    }
  },

  "postCreateCommand": "npm install -g @google/gemini-cli",
  "remoteUser": "root"
}