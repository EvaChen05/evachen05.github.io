---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { projects } from '@data/projects';
import { localeText } from '@data/i18n';

const textEn = localeText.en.home;
const textZh = localeText.zh.home;
---

<Layout titleEn={textEn.title} titleZh={textZh.title}>
  <div class="max-w-7xl mx-auto px-6">
    <!-- Hero Section -->
    <section class="min-h-[80vh] flex flex-col justify-center relative overflow-hidden pt-12">
      <div class="grid grid-cols-12 gap-8 items-end mb-24">
        <div class="col-span-12 md:col-span-7 relative">
          <h1 class="text-[clamp(4rem,10vw,8rem)] leading-[0.85] uppercase tracking-tighter mb-12 relative z-0">
            <!-- English: DESIGN FOR / HUMAN (purple) / CONNECTION. -->
            <span class="lang-en-block">
              {textEn.hero[0]} <br />
              <span class="text-[#a855f7]">{textEn.hero[1]}</span> <br />
              {textEn.hero[2]}
            </span>
            <!-- Chinese: 让设计 / 成为联结 / 人与人(purple)的桥 -->
            <span class="lang-zh-block">
              {textZh.hero[0]} <br />
              {textZh.hero[1]} <br />
              <span class="text-[#a855f7]">{textZh.hero[2]}</span>{textZh.hero[3]}
            </span>
          </h1>
          <div class="max-w-xl border-l-4 border-black pl-10 mt-16">
            <p class="text-xl md:text-2xl leading-relaxed text-black/80 font-medium italic">
              <span class="lang-en-block">{textEn.intro}</span>
              <span class="lang-zh-block">{textZh.intro}</span>
            </p>
          </div>
        </div>
        
        <div class="hidden md:flex col-span-5 flex-col items-end gap-1 font-bold text-[clamp(2rem,6vw,4rem)] leading-none text-right tracking-[0.2em] uppercase opacity-20 select-none pointer-events-none">
          <span>P O R T</span>
          <span>F O L I O</span>
          <div class="flex flex-col items-end gap-2 mt-8 pointer-events-auto">
            <a href="#case-studies" class="text-[12px] tracking-[1em] text-black opacity-100 hover:opacity-70 transition-opacity">
              <span class="lang-en">{textEn.caseStudies}</span><span class="lang-zh">{textZh.caseStudies}</span> / 2024-2026
            </a>
          </div>
        </div>
      </div>

      <!-- Scroll indicator -->
      <div class="flex justify-between items-center text-[11px] uppercase tracking-[0.5em] opacity-40 py-12">
        <div class="flex gap-12">
            <span><span class="lang-en">{textEn.scrollDown}</span><span class="lang-zh">{textZh.scrollDown}</span></span>
            <span><span class="lang-en">{textEn.location}</span><span class="lang-zh">{textZh.location}</span></span>
        </div>
        <span><span class="lang-en">{textEn.role}</span><span class="lang-zh">{textZh.role}</span></span>
      </div>
    </section>

    <!-- Project List Section -->
    <section id="case-studies" class="mt-32">
      <div class="mb-24 flex flex-col md:flex-row md:items-baseline gap-4 md:gap-12">
        <h2 class="text-5xl font-bold uppercase tracking-tight">
          <span class="lang-en">{textEn.caseStudies}</span>
          <span class="lang-zh">{textZh.caseStudies}</span>
        </h2>
        <div class="h-[1px] flex-grow bg-black/5 hidden md:block"></div>
        <span class="text-[12px] uppercase tracking-[0.4em] font-bold opacity-40">Portfolio Showcase v1.0</span>
      </div>

      <div class="space-y-0">
        {projects
          .filter(p => p.id !== 'project-1' && p.id !== 'project-2')
          .map((project) => (
          <ProjectCard project={project} />
        ))}
      </div>
    </section>

    <!-- Connect section -->
    <section class="mt-48 pb-24 grid grid-cols-1 md:grid-cols-3 gap-16 border-t border-black/5 pt-24">
        <div>
            <h3 class="text-sm font-bold uppercase tracking-[0.4em] mb-10">
              <span class="lang-en">{textEn.approach}</span>
              <span class="lang-zh">{textZh.approach}</span>
            </h3>
            <p class="text-[16px] leading-relaxed text-black/60">
              <span class="lang-en-block">{textEn.approachDescription}</span>
              <span class="lang-zh-block">{textZh.approachDescription}</span>
            </p>
        </div>
        <div>
            <h3 class="text-sm font-bold uppercase tracking-[0.4em] mb-10">
              <span class="lang-en">{textEn.current}</span>
              <span class="lang-zh">{textZh.current}</span>
            </h3>
            <p class="text-[16px] leading-relaxed text-black/60">
              <span class="lang-en-block">{textEn.currentDescription}</span>
              <span class="lang-zh-block">{textZh.currentDescription}</span>
            </p>
        </div>
        <div>
            <h3 class="text-sm font-bold uppercase tracking-[0.4em] mb-10">
              <span class="lang-en">{textEn.connect}</span>
              <span class="lang-zh">{textZh.connect}</span>
            </h3>
            <div class="flex flex-col gap-3 text-[16px] font-bold uppercase tracking-widest underline underline-offset-8 decoration-black/20 hover:decoration-black transition-colors">
                <a href="mailto:cccyf@uw.edu">Email &rarr;</a>
                <a href="https://www.linkedin.com/in/yifan-chen-209903386/">LinkedIn &rarr;</a>
            </div>
        </div>
    </section>
  </div>
</Layout>
