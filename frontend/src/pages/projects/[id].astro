---
import Layout from '../../layouts/Layout.astro';
import { projects } from '@data/projects';
import { caseStudyText, isChinese, localeText } from '@data/i18n';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const locale = isChinese(Astro.url.pathname) ? 'zh' : 'en';
const content = locale === 'zh' ? project.zh : project;
const labels = localeText[locale].project;
const studyText = caseStudyText[locale];
const homePath = locale === 'zh' ? '/zh/' : '/';

const isMakersLoop = project.id === 'makers-loop';
const isTheBridge = project.id === 'the-bridge';
const isRemindMe = project.id === 'remind-me';
const isMuseumOfGlass = project.id === 'museum-of-glass';

// Assets for Museum of Glass
const glassAssets = {
  hero: "/images/museum_of_glass/hero-image.png",
  logo: "/images/museum_of_glass/logo-primary.jpg",
  palette: "/images/museum_of_glass/hero-image.png",
  typography: "/images/museum_of_glass/typography.png",
  digitalArtifact: "/images/museum_of_glass/digital-artifact.png",
  artifactExploration: "/images/museum_of_glass/hero-image.png",
  physicalArtifact: "/images/museum_of_glass/physical_artifact.jpg",
  logoAlt1: "/images/museum_of_glass/logo_alt_1.png",
  logoAlt2: "/images/museum_of_glass/logo_alt_2.png"
};

// Assets for Makers Loop
const makersAssets = {
  sketches: ["/images/makers_loop/图片1.jpg", "/images/makers_loop/图片2.jpg", "/images/makers_loop/图片3.jpg"],
  prototype: "/images/makers_loop/图片4.png",
  screenshots: ["/images/makers_loop/2026-04-13 215944.png", "/images/makers_loop/2026-04-13 220016.png"]
};

// Assets for The Bridge
const bridgeAssets = {
  highFi: "/images/the_bridge/03 high.png",
  midFi: "/images/the_bridge/02 mid.png",
  lowFi: "/images/the_bridge/01 low.png",
  personas: ["/images/the_bridge/mary persona.png", "/images/the_bridge/anna persona.png"],
  ia: "/images/the_bridge/info arch.png"
};

// Assets for RemindME
const remindmeAssets = {
  demoGif: "/images/remindme/demo.gif",
  cardExample: "/images/remindme/hero.png",
  screenshots: [
    "/images/remindme/remindme (1).png",
    "/images/remindme/remindme (2).png",
    "/images/remindme/remindme (3).png",
    "/images/remindme/remindme (4).png"
  ]
};
---

<Layout title={`${content.title} | ${labels.caseStudy}`}>
  <div class="max-w-7xl mx-auto px-6 pt-32">
    <!-- Breadcrumb -->
    <div class="mb-24">
      <a href={homePath} class="text-[12px] font-bold uppercase tracking-[0.4em] text-black/40 hover:text-black transition-colors mb-8 block">&larr; {labels.back}</a>
      
      <div class="grid grid-cols-12 gap-12 items-start">
        <div class="col-span-12 md:col-span-8">
          <h1 
            class="text-[clamp(3rem,8vw,6rem)] leading-[0.9] uppercase tracking-tighter mb-12"
            style={isMuseumOfGlass ? "font-family: 'Horizon', sans-serif;" : ""}
          >
            {content.title}
          </h1>
          <div class="relative">
            <p class="text-2xl md:text-3xl leading-relaxed text-black/80 max-w-3xl border-l-4 border-black pl-10 italic">
              {content.description}
              {isTheBridge && (
                <a href="#prototype" class="inline-block ml-2 text-purple-600 font-bold border-b border-purple-600 hover:text-purple-800 hover:border-purple-800 transition-all">
                  {studyText.common.tryPrototype}
                </a>
              )}
            </p>
          </div>
        </div>
        
        <div class="col-span-12 md:col-span-4 space-y-16 pt-4">
          <div class="sticky top-32 space-y-16">
            <div>
              <h3 class="text-sm font-bold uppercase tracking-[0.4em] mb-6 text-black/40">{labels.role}</h3>
              <p class="text-base font-semibold uppercase tracking-widest">{isRemindMe ? studyText.common.roles.remindMe : studyText.common.roles.standard}</p>
            </div>
            {isMuseumOfGlass && (
              <>
                <div>
                  <h3 class="text-sm font-bold uppercase tracking-[0.4em] mb-6 text-black/40">{studyText.common.roles.designer}</h3>
                  <p class="text-base font-semibold uppercase tracking-widest">Eva Chen</p>
                </div>
                <div>
                  <h3 class="text-sm font-bold uppercase tracking-[0.4em] mb-6 text-black/40">{studyText.common.roles.course}</h3>
                  <p class="text-base font-semibold uppercase tracking-widest">HCDE308</p>
                </div>
              </>
            )}
            <div>
              <h3 class="text-sm font-bold uppercase tracking-[0.4em] mb-6 text-black/40">{labels.methods}</h3>
              <div class="flex flex-wrap gap-x-6 gap-y-2">
                {content.tags.map((tag) => (
                  <span class="text-[12px] uppercase tracking-[0.2em] font-bold text-black/60">/ {tag}</span>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Table of Contents Section -->
    <section class="mb-32 border-t border-black/10 pt-16">
      <div class="flex flex-col md:flex-row md:items-center gap-8 md:gap-16">
        <h3 class="text-xs font-black uppercase tracking-[0.5em] text-black whitespace-nowrap">{labels.jumpTo}</h3>
        <nav class="flex flex-nowrap gap-x-12 overflow-x-auto pb-4 md:pb-0 no-scrollbar">
          {isRemindMe && (
            <>
              <a href="#summary" class="text-[13px] uppercase tracking-[0.3em] font-black text-black/50 hover:text-black transition-all hover:translate-y-[-1px]">/ 00 {studyText.remindMe.toc[0]}</a>
              <a href="#dashboard" class="text-[13px] uppercase tracking-[0.3em] font-black text-black/50 hover:text-black transition-all hover:translate-y-[-1px]">/ 01 {studyText.remindMe.toc[1]}</a>
              <a href="#technical" class="text-[13px] uppercase tracking-[0.3em] font-black text-black/50 hover:text-black transition-all hover:translate-y-[-1px]">/ 02 {studyText.remindMe.toc[2]}</a>
            </>
          )}
          {isTheBridge && (
            <>
              <a href="#summary" class="text-[13px] uppercase tracking-[0.3em] font-black text-black/50 hover:text-black transition-all hover:translate-y-[-1px]">/ 00 {studyText.bridge.toc[0]}</a>
              <a href="#prototype-main" class="text-[13px] uppercase tracking-[0.3em] font-black text-black/50 hover:text-black transition-all hover:translate-y-[-1px]">/ 01 {studyText.bridge.toc[1]}</a>
              <a href="#strategy" class="text-[13px] uppercase tracking-[0.3em] font-black text-black/50 hover:text-black transition-all hover:translate-y-[-1px]">/ 02 {studyText.bridge.toc[2]}</a>
              <a href="#prototype" class="text-[13px] uppercase tracking-[0.3em] font-black text-black/50 hover:text-black transition-all hover:translate-y-[-1px]">/ 03 {studyText.bridge.toc[3]}</a>
            </>
          )}
          {isMakersLoop && (
            <>
              <a href="#concept" class="text-[13px] uppercase tracking-[0.3em] font-black text-black/50 hover:text-black transition-all hover:translate-y-[-1px]">/ 01 {studyText.makersLoop.toc[0]}</a>
              <a href="#goals" class="text-[13px] uppercase tracking-[0.3em] font-black text-black/50 hover:text-black transition-all hover:translate-y-[-1px]">/ 02 {studyText.makersLoop.toc[1]}</a>
              <a href="#implementation" class="text-[13px] uppercase tracking-[0.3em] font-black text-black/50 hover:text-black transition-all hover:translate-y-[-1px]">/ 03 {studyText.makersLoop.toc[2]}</a>
              <a href="#evaluation" class="text-[13px] uppercase tracking-[0.3em] font-black text-black/50 hover:text-black transition-all hover:translate-y-[-1px]">/ 04 {studyText.makersLoop.toc[3]}</a>
            </>
          )}
          {isMuseumOfGlass && (
            <>
              <a href="#overview" class="text-[13px] uppercase tracking-[0.3em] font-black text-black/50 hover:text-black transition-all hover:translate-y-[-1px]">/ 00 {studyText.museum.toc[0]}</a>
              <a href="#context" class="text-[13px] uppercase tracking-[0.3em] font-black text-black/50 hover:text-black transition-all hover:translate-y-[-1px]">/ 01 {studyText.museum.toc[1]}</a>
              <a href="#intent" class="text-[13px] uppercase tracking-[0.3em] font-black text-black/50 hover:text-black transition-all hover:translate-y-[-1px]">/ 02 {studyText.museum.toc[2]}</a>
              <a href="#identity" class="text-[13px] uppercase tracking-[0.3em] font-black text-black/50 hover:text-black transition-all hover:translate-y-[-1px]">/ 03 {studyText.museum.toc[3]}</a>
              <a href="#artifacts" class="text-[13px] uppercase tracking-[0.3em] font-black text-black/50 hover:text-black transition-all hover:translate-y-[-1px]">/ 04 {studyText.museum.toc[4]}</a>
              <a href="#appendix" class="text-[13px] uppercase tracking-[0.3em] font-black text-black/50 hover:text-black transition-all hover:translate-y-[-1px]">/ 05 {studyText.museum.toc[5]}</a>
            </>
          )}
        </nav>
      </div>
    </section>

    {isRemindMe && (
      <div class="space-y-48 pb-48">
        <!-- TL;DR SUMMARY -->
        <section id="summary" class="bg-black text-white p-12 md:p-24 -mx-6 md:mx-0 scroll-mt-32">
          <div class="max-w-4xl mx-auto">
            <h2 class="text-4xl font-black uppercase tracking-tighter mb-12 text-white">00 / {studyText.remindMe.summary[0]}</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-20">
              <div>
                <h3 class="text-xl font-bold uppercase mb-4 tracking-wide text-white">{studyText.remindMe.summary[1]}</h3>
                <p class="text-lg text-white/80 leading-relaxed font-light text-balance">
                  {studyText.remindMe.summary[2]}
                </p>
              </div>
              <div>
                <h3 class="text-xl font-bold uppercase mb-4 tracking-wide text-white">{studyText.remindMe.summary[3]}</h3>
                <p class="text-lg text-white/80 leading-relaxed font-light text-balance">
                  {studyText.remindMe.summary[4]}
                </p>
              </div>
            </div>
          </div>
        </section>

        <!-- CORE RESULT: Main Dashboard Interface with ANIMATED GIF -->
        <section id="dashboard" class="w-full scroll-mt-32">
            <div class="border-y border-black/5 py-16 text-center">
                <!-- Using demo.gif directly for animation -->
                <img 
                  src={remindmeAssets.demoGif} 
                  alt={studyText.remindMe.dashboard[0]}
                  class="w-full h-auto max-h-[40vh] object-contain mx-auto shadow-2xl" 
                />
                <p class="mt-10 text-xs uppercase tracking-[0.3em] opacity-40 font-bold">{studyText.remindMe.dashboard[1]}</p>
                <p class="mt-6 text-base text-black/60 leading-relaxed max-w-2xl mx-auto italic">
                  {studyText.remindMe.dashboard[2]}
                </p>
            </div>
        </section>


        <!-- INTERACTIVE DETAIL SECTION -->
        <section class="max-w-5xl mx-auto border-t-2 border-black pt-20">
          <details class="group">
            <summary class="flex justify-between items-center cursor-pointer list-none py-8 px-6 border-b border-black/5 mb-16 hover:bg-black/[0.02] transition-colors rounded-lg">
              <h2 class="text-3xl font-bold uppercase tracking-tight group-hover:translate-x-2 transition-transform duration-300">{studyText.remindMe.details[0]}</h2>
              <span class="text-5xl group-open:rotate-45 transition-transform duration-300 font-extralight text-black/30 group-hover:text-black">+</span>
            </summary>
            
            <div class="space-y-48 pb-32">
              <!-- Feature List -->
              <div class="space-y-16">
                <h3 class="text-xs font-bold uppercase tracking-[0.4em] text-black/40">01 / {studyText.remindMe.details[1]}</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
                  <div class="space-y-6 border-l border-black pl-8">
                    <h4 class="font-bold uppercase text-lg tracking-tight">{studyText.remindMe.details[2]}</h4>
                    <p class="text-base text-black/70 leading-relaxed">{studyText.remindMe.details[3]}</p>
                  </div>
                  <div class="space-y-6 border-l border-black pl-8">
                    <h4 class="font-bold uppercase text-lg tracking-tight">{studyText.remindMe.details[4]}</h4>
                    <p class="text-base text-black/70 leading-relaxed">{studyText.remindMe.details[5]}</p>
                  </div>
                </div>
              </div>

              <!-- Interface Screenshots -->
              <div class="space-y-20">
                <h3 class="text-xs font-bold uppercase tracking-[0.4em] text-black/40">02 / {studyText.remindMe.details[6]}</h3>
                <div class="grid grid-cols-1 gap-32">
                  <!-- The Card Example (Static) -->
                  <div class="space-y-8 text-center">
                    <div class="border border-black/10 bg-white p-4 md:p-8">
                        <img src={remindmeAssets.cardExample} alt={studyText.remindMe.card[0]} class="w-full h-auto mx-auto shadow-sm" />
                    </div>
                    <p class="text-[11px] uppercase tracking-widest opacity-40 font-bold max-w-lg mx-auto italic">{studyText.remindMe.card[1]}</p>
                    <p class="mt-6 text-sm text-black/50 leading-relaxed max-w-xl mx-auto">
                      {studyText.remindMe.card[2]}
                    </p>
                  </div>

                  {remindmeAssets.screenshots.map((img, index) => (
                    <div class="space-y-8 text-center">
                        <div class="border border-black/10 bg-white p-4 md:p-8">
                            <img src={img} alt={studyText.remindMe.screens.alts[index]} class="w-full h-auto mx-auto shadow-xl" />
                        </div>
                        <p class="text-xs uppercase tracking-widest opacity-40 font-bold">{studyText.remindMe.screens.caption} {studyText.remindMe.screens.states[index]}</p>
                        <p class="mt-4 text-sm text-black/50 leading-relaxed max-w-xl mx-auto">
                          {studyText.remindMe.screens.description}
                        </p>
                    </div>
                  ))}
                </div>
              </div>

              <!-- Video Link Section -->
              <div class="pt-32 border-t border-black/5 text-center">
                <h3 class="text-xs font-bold uppercase tracking-[0.4em] text-black/40 mb-12 text-black/40">03 / {studyText.remindMe.video[0]}</h3>
                <a href="https://www.youtube.com/watch?v=YPWUWVT1iq8" target="_blank" class="inline-block px-16 py-8 bg-black text-white text-sm uppercase tracking-[0.3em] font-bold hover:bg-black/80 transition-all">
                    {studyText.remindMe.video[1]}
                </a>
              </div>
            </div>
          </details>
        </section>
      </div>
    )}

    {isTheBridge && (
      <div class="space-y-48 pb-48">
        <!-- TL;DR SUMMARY -->
        <section id="summary" class="bg-black text-white p-12 md:p-24 -mx-6 md:mx-0 scroll-mt-32">
          <div class="max-w-4xl mx-auto">
            <h2 class="text-4xl font-black uppercase tracking-tighter mb-12 text-white">00 / {studyText.bridge.summary[0]}</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-20">
              <div>
                <h3 class="text-xl font-bold uppercase mb-6 tracking-wide text-white">{studyText.bridge.summary[1]}</h3>
                <p class="text-lg text-white/80 leading-relaxed font-light text-balance">
                  {studyText.bridge.summary[2]}
                </p>
              </div>
              <div>
                <h3 class="text-xl font-bold uppercase mb-6 tracking-wide text-white">{studyText.bridge.summary[3]}</h3>
                <p class="text-lg text-white/80 leading-relaxed font-light text-balance">
                  {studyText.bridge.summary[4]}
                </p>
              </div>
            </div>
          </div>
        </section>

        <!-- Main Image -->
        <section id="prototype-main" class="w-full scroll-mt-32">
            <div class="bg-white border border-black/5 p-4 md:p-12 shadow-sm text-center">
                <img src={bridgeAssets.highFi} alt={studyText.bridge.main[0]} class="w-full h-auto max-h-[90vh] object-contain mx-auto" />
                <p class="mt-8 text-xs uppercase tracking-widest text-center opacity-30 font-bold">{studyText.bridge.main[1]}</p>
                <p class="mt-6 text-base text-black/60 leading-relaxed max-w-2xl mx-auto italic">
                  {studyText.bridge.main[2]}
                </p>
            </div>
        </section>

        <!-- INTERACTIVE DETAIL SECTION -->
        <section id="strategy" class="max-w-5xl mx-auto border-t-2 border-black pt-20 scroll-mt-32">
          <details class="group">
            <summary class="flex justify-between items-center cursor-pointer list-none py-8 px-6 border-b border-black/5 mb-16 hover:bg-black/[0.02] transition-colors rounded-lg">
              <h2 class="text-3xl font-bold uppercase tracking-tight group-hover:translate-x-2 transition-transform duration-300">{studyText.bridge.details[0]}</h2>
              <span class="text-5xl group-open:rotate-45 transition-transform duration-300 font-extralight text-black/30 group-hover:text-black">+</span>
            </summary>
            
            <div class="space-y-48 pb-32">
              <div class="space-y-12">
                <h3 class="text-xs font-bold uppercase tracking-[0.4em] text-black/40">01 / {studyText.bridge.details[1]}</h3>
                <p class="text-2xl md:text-3xl leading-snug font-medium max-w-4xl italic">
                  {studyText.bridge.details[2]}
                </p>
              </div>

              <div class="space-y-16">
                <h3 class="text-xs font-bold uppercase tracking-[0.4em] text-black/40">02 / {studyText.bridge.details[3]}</h3>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
                  <div class="space-y-6 border-l border-black/10 pl-6">
                    <h4 class="font-bold uppercase text-lg tracking-tight">{studyText.bridge.details[4]}</h4>
                    <p class="text-base text-black/70 leading-relaxed">{studyText.bridge.details[5]}</p>
                  </div>
                  <div class="space-y-6 border-l border-black/10 pl-6">
                    <h4 class="font-bold uppercase text-lg tracking-tight">{studyText.bridge.details[6]}</h4>
                    <p class="text-base text-black/70 leading-relaxed">{studyText.bridge.details[7]}</p>
                  </div>
                  <div class="space-y-6 border-l border-black/10 pl-6">
                    <h4 class="font-bold uppercase text-lg tracking-tight">{studyText.bridge.details[8]}</h4>
                    <p class="text-base text-black/70 leading-relaxed">{studyText.bridge.details[9]}</p>
                  </div>
                </div>
              </div>

              <div class="space-y-20">
                <h3 class="text-xs font-bold uppercase tracking-[0.4em] text-black/40">03 / {studyText.bridge.details[10]}</h3>
                <div class="space-y-16">
                  {bridgeAssets.personas.map((img) => (
                    <div class="border border-black/10 bg-white p-4 md:p-12 text-center">
                        <img src={img} alt={studyText.bridge.details[11]} class="w-full h-auto" />
                        <p class="mt-8 text-sm text-black/50 leading-relaxed max-w-xl mx-auto">
                          {studyText.bridge.details[12]}
                        </p>
                    </div>
                  ))}
                </div>
              </div>

              <div class="space-y-20">
                <h3 class="text-xs font-bold uppercase tracking-[0.4em] text-black/40">04 / {studyText.bridge.details[13]}</h3>
                <div class="space-y-24">
                  <div class="space-y-8 text-center">
                    <img src={bridgeAssets.lowFi} alt={studyText.bridge.details[14]} class="w-full h-auto border border-black/5" />
                    <p class="text-xs uppercase tracking-widest opacity-40 font-bold">{studyText.bridge.details[15]}</p>
                    <p class="mt-4 text-sm text-black/50 leading-relaxed max-w-xl mx-auto">
                      {studyText.bridge.details[16]}
                    </p>
                  </div>
                  <div class="space-y-8 text-center">
                    <img src={bridgeAssets.midFi} alt={studyText.bridge.details[17]} class="w-full h-auto border border-black/5" />
                    <p class="text-xs uppercase tracking-widest opacity-40 font-bold">{studyText.bridge.details[18]}</p>
                    <p class="mt-4 text-sm text-black/50 leading-relaxed max-w-xl mx-auto">
                      {studyText.bridge.details[19]}
                    </p>
                  </div>
                </div>
              </div>

              <div class="pt-32 border-t border-black/5">
                <h3 class="text-xs font-bold uppercase tracking-[0.4em] text-black/40 mb-12 text-center">05 / {studyText.bridge.details[20]}</h3>
                <div class="bg-white border border-black/10 p-4 md:p-12 shadow-lg text-center">
                    <img src={bridgeAssets.highFi} alt={studyText.bridge.details[21]} class="w-full h-auto mx-auto" />
                    <p class="mt-8 text-sm text-black/50 leading-relaxed max-w-xl mx-auto italic">
                      {studyText.bridge.details[22]}
                    </p>
                </div>
              </div>
              
              <!-- Interactive Figma Prototype -->
              <div id="prototype" class="pt-48 border-t border-black/5 scroll-mt-32">
                <div class="text-center mb-24">
                  <h3 class="text-3xl md:text-5xl font-bold uppercase tracking-tighter mb-6">{studyText.bridge.details[23]}</h3>
                  <p class="text-lg text-black/60 max-w-2xl mx-auto leading-relaxed">
                    {studyText.bridge.details[24]}
                  </p>
                </div>
                
                <!-- REFINED MOBILE MOCKUP (75% Scale) -->
                <div class="relative max-w-lg mx-auto mb-32 text-center">
                  <!-- Phone Frame: Thinner bezels (p-2 md:p-3) -->
                  <div class="relative z-20 bg-black p-2 md:p-3 rounded-[4rem] shadow-[0_40px_80px_-15px_rgba(0,0,0,0.3)] border-[1px] border-white/10 overflow-hidden inline-block w-full">
                    <!-- Screen Container -->
                    <div class="relative w-full aspect-[9/19] overflow-hidden rounded-[3.5rem] bg-white">
                      <!-- Scaled Dynamic Island -->
                      <div class="absolute top-3 left-1/2 -translate-x-1/2 w-32 h-8 bg-black rounded-full z-30 pointer-events-none"></div>
                      
                      <iframe 
                        class="absolute inset-0 w-full h-full border-none scale-[1.20] origin-center"
                        src="https://www.figma.com/embed?embed_host=share&url=https%3A%2F%2Fwww.figma.com%2Fproto%2Fywb9PVuSmza6l1wdgvp04F%2FHigh-fidelity-prototype---The-Bridge%3Fnode-id%3D460-710%26starting-point-node-id%3D460%253A710%26t%3DD0hGgXYoLBFKIPs4-1&hide-ui=1" 
                        allowfullscreen
                      ></iframe>
                    </div>
                  </div>

                  <!-- Side Buttons (Refined) -->
                  <div class="absolute -left-1 top-24 w-1 h-12 bg-black/20 rounded-l-sm"></div>
                  <div class="absolute -left-1 top-40 w-1 h-16 bg-black/20 rounded-l-sm"></div>
                  <div class="absolute -left-1 top-60 w-1 h-16 bg-black/20 rounded-l-sm"></div>
                  <div class="absolute -right-1 top-44 w-1 h-24 bg-black/20 rounded-r-sm"></div>

                  <!-- Floor Shadow -->
                  <div class="absolute -bottom-10 left-1/2 -translate-x-1/2 w-4/5 h-10 bg-black/5 blur-2xl rounded-full -z-10"></div>
                </div>
              </div>
            </div>
          </details>
        </section>
      </div>
    )}

    {isMakersLoop && (
      <div class="space-y-64 pb-64">
        <section id="concept" class="grid grid-cols-12 gap-12 scroll-mt-32">
