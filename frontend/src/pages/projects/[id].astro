---
import Layout from '../../layouts/Layout.astro';
import { projects } from '@data/projects';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;

const isMakersLoop = project.id === 'makers-loop';
const isTheBridge = project.id === 'the-bridge';
const isRemindMe = project.id === 'remind-me';
const isMuseumOfGlass = project.id === 'museum-of-glass';

// Assets for Museum of Glass
const glassAssets = {
  hero: "/images/museum_of_glass/hero-image.png",
  logo: "/images/museum_of_glass/logo-primary.jpg",
  palette: "/images/museum_of_glass/hero-image.png",
  typography: "/images/museum_of_glass/typography.png",
  digitalArtifact: "/images/museum_of_glass/digital-artifact.png",
  artifactExploration: "/images/museum_of_glass/hero-image.png",
  physicalArtifact: "/images/museum_of_glass/physical_artifact.jpg",
  logoAlt1: "/images/museum_of_glass/logo_alt_1.png",
  logoAlt2: "/images/museum_of_glass/logo_alt_2.png"
};

// Assets for Makers Loop
const makersAssets = {
  sketches: ["/images/makers_loop/图片1.jpg", "/images/makers_loop/图片2.jpg", "/images/makers_loop/图片3.jpg"],
  prototype: "/images/makers_loop/图片4.png",
  screenshots: ["/images/makers_loop/2026-04-13 215944.png", "/images/makers_loop/2026-04-13 220016.png"]
};

// Assets for The Bridge
const bridgeAssets = {
  highFi: "/images/the_bridge/03 high.png",
  midFi: "/images/the_bridge/02 mid.png",
  lowFi: "/images/the_bridge/01 low.png",
  personas: ["/images/the_bridge/mary persona.png", "/images/the_bridge/anna persona.png"],
  ia: "/images/the_bridge/info arch.png"
};

// Assets for RemindME
const remindmeAssets = {
  demoGif: "/images/remindme/demo.gif",
  cardExample: "/images/remindme/hero.png",
  screenshots: [
    "/images/remindme/remindme (1).png",
    "/images/remindme/remindme (2).png",
    "/images/remindme/remindme (3).png",
    "/images/remindme/remindme (4).png"
  ]
};
---

<Layout title={`${project.title} | Case Study`}>
  <div class="max-w-7xl mx-auto px-6 pt-32">
    <!-- Breadcrumb -->
    <div class="mb-24">
      <a href="/" class="text-[12px] font-bold uppercase tracking-[0.4em] text-black/40 hover:text-black transition-colors mb-8 block">&larr; Back to Portfolio</a>
      
      <div class="grid grid-cols-12 gap-12 items-start">
        <div class="col-span-12 md:col-span-8">
          <h1 
            class="text-[clamp(3rem,8vw,6rem)] leading-[0.9] uppercase tracking-tighter mb-12"
            style={isMuseumOfGlass ? "font-family: 'Horizon', sans-serif;" : ""}
          >
            {project.title}
          </h1>
          <div class="relative">
            <p class="text-2xl md:text-3xl leading-relaxed text-black/80 max-w-3xl border-l-4 border-black pl-10 italic">
              {project.description}
              {isTheBridge && (
                <a href="#prototype" class="inline-block ml-2 text-purple-600 font-bold border-b border-purple-600 hover:text-purple-800 hover:border-purple-800 transition-all">
                  Try High-Fidelity Prototype
                </a>
              )}
            </p>
          </div>
        </div>
        
        <div class="col-span-12 md:col-span-4 space-y-16 pt-4">
          <div class="sticky top-32 space-y-16">
            <div>
              <h3 class="text-sm font-bold uppercase tracking-[0.4em] mb-6 text-black/40">Role</h3>
              <p class="text-base font-semibold uppercase tracking-widest">{isRemindMe ? 'Full-stack Developer & Designer' : 'UX Researcher & Designer'}</p>
            </div>
            {isMuseumOfGlass && (
              <>
                <div>
                  <h3 class="text-sm font-bold uppercase tracking-[0.4em] mb-6 text-black/40">Designer</h3>
                  <p class="text-base font-semibold uppercase tracking-widest">Eva Chen</p>
                </div>
                <div>
                  <h3 class="text-sm font-bold uppercase tracking-[0.4em] mb-6 text-black/40">Course</h3>
                  <p class="text-base font-semibold uppercase tracking-widest">HCDE308</p>
                </div>
              </>
            )}
            <div>
              <h3 class="text-sm font-bold uppercase tracking-[0.4em] mb-6 text-black/40">Methods</h3>
              <div class="flex flex-wrap gap-x-6 gap-y-2">
                {project.tags.map((tag) => (
                  <span class="text-[12px] uppercase tracking-[0.2em] font-bold text-black/60">/ {tag}</span>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Table of Contents Section -->
    <section class="mb-32 border-t border-black/10 pt-16">
      <div class="flex flex-col md:flex-row md:items-center gap-8 md:gap-16">
        <h3 class="text-xs font-black uppercase tracking-[0.5em] text-black whitespace-nowrap">Jump to Section</h3>
        <nav class="flex flex-nowrap gap-x-12 overflow-x-auto pb-4 md:pb-0 no-scrollbar">
          {isRemindMe && (
            <>
              <a href="#summary" class="text-[13px] uppercase tracking-[0.3em] font-black text-black/50 hover:text-black transition-all hover:translate-y-[-1px]">/ 00 Summary</a>
              <a href="#dashboard" class="text-[13px] uppercase tracking-[0.3em] font-black text-black/50 hover:text-black transition-all hover:translate-y-[-1px]">/ 01 Dashboard</a>
              <a href="#technical" class="text-[13px] uppercase tracking-[0.3em] font-black text-black/50 hover:text-black transition-all hover:translate-y-[-1px]">/ 02 Technical</a>
            </>
          )}
          {isTheBridge && (
            <>
              <a href="#summary" class="text-[13px] uppercase tracking-[0.3em] font-black text-black/50 hover:text-black transition-all hover:translate-y-[-1px]">/ 00 Summary</a>
              <a href="#prototype-main" class="text-[13px] uppercase tracking-[0.3em] font-black text-black/50 hover:text-black transition-all hover:translate-y-[-1px]">/ 01 Prototype</a>
              <a href="#strategy" class="text-[13px] uppercase tracking-[0.3em] font-black text-black/50 hover:text-black transition-all hover:translate-y-[-1px]">/ 02 Strategy</a>
              <a href="#prototype" class="text-[13px] uppercase tracking-[0.3em] font-black text-black/50 hover:text-black transition-all hover:translate-y-[-1px]">/ 03 Interactive</a>
            </>
          )}
          {isMakersLoop && (
            <>
              <a href="#concept" class="text-[13px] uppercase tracking-[0.3em] font-black text-black/50 hover:text-black transition-all hover:translate-y-[-1px]">/ 01 Concept</a>
              <a href="#goals" class="text-[13px] uppercase tracking-[0.3em] font-black text-black/50 hover:text-black transition-all hover:translate-y-[-1px]">/ 02 Goals</a>
              <a href="#implementation" class="text-[13px] uppercase tracking-[0.3em] font-black text-black/50 hover:text-black transition-all hover:translate-y-[-1px]">/ 03 Implementation</a>
              <a href="#evaluation" class="text-[13px] uppercase tracking-[0.3em] font-black text-black/50 hover:text-black transition-all hover:translate-y-[-1px]">/ 04 Evaluation</a>
            </>
          )}
          {isMuseumOfGlass && (
            <>
              <a href="#overview" class="text-[13px] uppercase tracking-[0.3em] font-black text-black/50 hover:text-black transition-all hover:translate-y-[-1px]">/ 00 Overview</a>
              <a href="#context" class="text-[13px] uppercase tracking-[0.3em] font-black text-black/50 hover:text-black transition-all hover:translate-y-[-1px]">/ 01 Context</a>
              <a href="#intent" class="text-[13px] uppercase tracking-[0.3em] font-black text-black/50 hover:text-black transition-all hover:translate-y-[-1px]">/ 02 Design Intent</a>
              <a href="#identity" class="text-[13px] uppercase tracking-[0.3em] font-black text-black/50 hover:text-black transition-all hover:translate-y-[-1px]">/ 03 Identity</a>
              <a href="#artifacts" class="text-[13px] uppercase tracking-[0.3em] font-black text-black/50 hover:text-black transition-all hover:translate-y-[-1px]">/ 04 Artifacts</a>
              <a href="#appendix" class="text-[13px] uppercase tracking-[0.3em] font-black text-black/50 hover:text-black transition-all hover:translate-y-[-1px]">/ 05 Appendix</a>
            </>
          )}
        </nav>
      </div>
    </section>

    {isRemindMe && (
      <div class="space-y-48 pb-48">
        <!-- TL;DR SUMMARY -->
        <section id="summary" class="bg-black text-white p-12 md:p-24 -mx-6 md:mx-0 scroll-mt-32">
          <div class="max-w-4xl mx-auto">
            <h2 class="text-4xl font-black uppercase tracking-tighter mb-12 text-white">00 / Quick Summary</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-20">
              <div>
                <h3 class="text-xl font-bold uppercase mb-4 tracking-wide text-white">The Concept</h3>
                <p class="text-lg text-white/80 leading-relaxed font-light text-balance">
                  A Python Flask application that automates the calculation of departure times by bridging Google Calendar events with real-time Google Maps distance data.
                </p>
              </div>
              <div>
                <h3 class="text-xl font-bold uppercase mb-4 tracking-wide text-white">The Problem</h3>
                <p class="text-lg text-white/80 leading-relaxed font-light text-balance">
                  Users often experience "switching friction" when manually calculating travel times between back-to-back calendar events—a process that is inefficient and prone to error.
                </p>
              </div>
            </div>
          </div>
        </section>

        <!-- CORE RESULT: Main Dashboard Interface with ANIMATED GIF -->
        <section id="dashboard" class="w-full scroll-mt-32">
            <div class="border-y border-black/5 py-16 text-center">
                <!-- Using demo.gif directly for animation -->
                <img 
                  src={remindmeAssets.demoGif} 
                  alt="RemindMe Main Dashboard Animation" 
                  class="w-full h-auto max-h-[40vh] object-contain mx-auto shadow-2xl" 
                />
                <p class="mt-10 text-xs uppercase tracking-[0.3em] opacity-40 font-bold">Main Dashboard Interface</p>
                <p class="mt-6 text-base text-black/60 leading-relaxed max-w-2xl mx-auto italic">
                  Detailed design exploration and visual analysis. This section showcases the iterative development of the interface, highlighting key features and user flow optimizations implemented to enhance the overall experience.
                </p>
            </div>
        </section>


        <!-- INTERACTIVE DETAIL SECTION -->
        <section class="max-w-5xl mx-auto border-t-2 border-black pt-20">
          <details class="group">
            <summary class="flex justify-between items-center cursor-pointer list-none py-8 px-6 border-b border-black/5 mb-16 hover:bg-black/[0.02] transition-colors rounded-lg">
              <h2 class="text-3xl font-bold uppercase tracking-tight group-hover:translate-x-2 transition-transform duration-300">Technical Process & Features</h2>
              <span class="text-5xl group-open:rotate-45 transition-transform duration-300 font-extralight text-black/30 group-hover:text-black">+</span>
            </summary>
            
            <div class="space-y-48 pb-32">
              <!-- Feature List -->
              <div class="space-y-16">
                <h3 class="text-xs font-bold uppercase tracking-[0.4em] text-black/40">01 / Core Features</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
                  <div class="space-y-6 border-l border-black pl-8">
                    <h4 class="font-bold uppercase text-lg tracking-tight">Google Calendar Sync</h4>
                    <p class="text-base text-black/70 leading-relaxed">Automatic retrieval of upcoming events using OAuth 2.0. Extracting event names, start times, and locations seamlessly.</p>
                  </div>
                  <div class="space-y-6 border-l border-black pl-8">
                    <h4 class="font-bold uppercase text-lg tracking-tight">Maps Integration</h4>
                    <p class="text-base text-black/70 leading-relaxed">Leveraging the Google Maps Distance Matrix API to calculate travel durations based on real-world geolocation and traffic.</p>
                  </div>
                </div>
              </div>

              <!-- Interface Screenshots -->
              <div class="space-y-20">
                <h3 class="text-xs font-bold uppercase tracking-[0.4em] text-black/40">02 / Design Details</h3>
                <div class="grid grid-cols-1 gap-32">
                  <!-- The Card Example (Static) -->
                  <div class="space-y-8 text-center">
                    <div class="border border-black/10 bg-white p-4 md:p-8">
                        <img src={remindmeAssets.cardExample} alt="Event Card Example" class="w-full h-auto mx-auto shadow-sm" />
                    </div>
                    <p class="text-[11px] uppercase tracking-widest opacity-40 font-bold max-w-lg mx-auto italic">Static Component Analysis: Event list with calculated departure times.</p>
                    <p class="mt-6 text-sm text-black/50 leading-relaxed max-w-xl mx-auto">
                      Iterative exploration of the component architecture, focusing on information density and visual hierarchy to ensure that critical data is immediately accessible to the user.
                    </p>
                  </div>

                  {remindmeAssets.screenshots.map((img, index) => (
                    <div class="space-y-8 text-center">
                        <div class="border border-black/10 bg-white p-4 md:p-8">
                            <img src={img} alt={`RemindMe Screen ${index + 1}`} class="w-full h-auto mx-auto shadow-xl" />
                        </div>
                        <p class="text-xs uppercase tracking-widest opacity-40 font-bold">Flow State: {index === 0 ? 'Authentication' : index === 1 ? 'Dashboard' : 'Notification'}</p>
                        <p class="mt-4 text-sm text-black/50 leading-relaxed max-w-xl mx-auto">
                          Visual synthesis of the user journey, mapping out the transition between different states and ensuring a cohesive aesthetic across the entire application interface.
                        </p>
                    </div>
                  ))}
                </div>
              </div>

              <!-- Video Link Section -->
              <div class="pt-32 border-t border-black/5 text-center">
                <h3 class="text-xs font-bold uppercase tracking-[0.4em] text-black/40 mb-12 text-black/40">03 / Watch in Action</h3>
                <a href="https://www.youtube.com/watch?v=YPWUWVT1iq8" target="_blank" class="inline-block px-16 py-8 bg-black text-white text-sm uppercase tracking-[0.3em] font-bold hover:bg-black/80 transition-all">
                    View Demo Video &rarr;
                </a>
              </div>
            </div>
          </details>
        </section>
      </div>
    )}

    {isTheBridge && (
      <div class="space-y-48 pb-48">
        <!-- TL;DR SUMMARY -->
        <section id="summary" class="bg-black text-white p-12 md:p-24 -mx-6 md:mx-0 scroll-mt-32">
          <div class="max-w-4xl mx-auto">
            <h2 class="text-4xl font-black uppercase tracking-tighter mb-12 text-white">00 / Quick Summary</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-20">
              <div>
                <h3 class="text-xl font-bold uppercase mb-6 tracking-wide text-white">The Concept</h3>
                <p class="text-lg text-white/80 leading-relaxed font-light text-balance">
                  A communication tool designed for college students and their parents to bridge emotional distance and reduce unintended pressure through "low-friction" check-ins.
                </p>
              </div>
              <div>
                <h3 class="text-xl font-bold uppercase mb-6 tracking-wide text-white">Key Insight</h3>
                <p class="text-lg text-white/80 leading-relaxed font-light text-balance">
                  Parents and students share the same goal of connection, but mismatched communication styles (advice vs. emotional support) often lead to perceived pressure and silence.
                </p>
              </div>
            </div>
          </div>
        </section>

        <!-- Main Image -->
        <section id="prototype-main" class="w-full scroll-mt-32">
            <div class="bg-white border border-black/5 p-4 md:p-12 shadow-sm text-center">
                <img src={bridgeAssets.highFi} alt="The Bridge High-Fi Prototype" class="w-full h-auto max-h-[90vh] object-contain mx-auto" />
                <p class="mt-8 text-xs uppercase tracking-widest text-center opacity-30 font-bold">Final High-Fidelity Prototype Display</p>
                <p class="mt-6 text-base text-black/60 leading-relaxed max-w-2xl mx-auto italic">
                  The high-fidelity prototype represents the culmination of extensive user research and iterative design. It focuses on providing a low-pressure environment for emotional check-ins, utilizing soft color palettes and intuitive navigation patterns.
                </p>
            </div>
        </section>

        <!-- INTERACTIVE DETAIL SECTION -->
        <section id="strategy" class="max-w-5xl mx-auto border-t-2 border-black pt-20 scroll-mt-32">
          <details class="group">
            <summary class="flex justify-between items-center cursor-pointer list-none py-8 px-6 border-b border-black/5 mb-16 hover:bg-black/[0.02] transition-colors rounded-lg">
              <h2 class="text-3xl font-bold uppercase tracking-tight group-hover:translate-x-2 transition-transform duration-300">Deep Dive: Process & Strategy</h2>
              <span class="text-5xl group-open:rotate-45 transition-transform duration-300 font-extralight text-black/30 group-hover:text-black">+</span>
            </summary>
            
            <div class="space-y-48 pb-32">
              <div class="space-y-12">
                <h3 class="text-xs font-bold uppercase tracking-[0.4em] text-black/40">01 / Problem Statement</h3>
                <p class="text-2xl md:text-3xl leading-snug font-medium max-w-4xl italic">
                  "How can we help college students and their parents create a peaceful, friendly space to talk and improve the overall family atmosphere?"
                </p>
              </div>

              <div class="space-y-16">
                <h3 class="text-xs font-bold uppercase tracking-[0.4em] text-black/40">02 / Research Findings</h3>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
                  <div class="space-y-6 border-l border-black/10 pl-6">
                    <h4 class="font-bold uppercase text-lg tracking-tight">Respect Gap</h4>
                    <p class="text-base text-black/70 leading-relaxed">Parents show respect through financial/academic support; students want to be listened to.</p>
                  </div>
                  <div class="space-y-6 border-l border-black/10 pl-6">
                    <h4 class="font-bold uppercase text-lg tracking-tight">Fear of Initiation</h4>
                    <p class="text-base text-black/70 leading-relaxed">Both sides want to reconnect after conflict but avoid starting conversations due to fear of friction.</p>
                  </div>
                  <div class="space-y-6 border-l border-black/10 pl-6">
                    <h4 class="font-bold uppercase text-lg tracking-tight">Invisible Needs</h4>
                    <p class="text-base text-black/70 leading-relaxed">Parents love through advice, students avoid escalation; both keep emotional needs hidden.</p>
                  </div>
                </div>
              </div>

              <div class="space-y-20">
                <h3 class="text-xs font-bold uppercase tracking-[0.4em] text-black/40">03 / Target Personas</h3>
                <div class="space-y-16">
                  {bridgeAssets.personas.map((img) => (
                    <div class="border border-black/10 bg-white p-4 md:p-12 text-center">
                        <img src={img} alt="Full Persona Sheet" class="w-full h-auto" />
                        <p class="mt-8 text-sm text-black/50 leading-relaxed max-w-xl mx-auto">
                          User personas derived from qualitative interviews with college students and their parents. These profiles helped guide the design direction by highlighting the specific emotional needs and communication barriers.
                        </p>
                    </div>
                  ))}
                </div>
              </div>

              <div class="space-y-20">
                <h3 class="text-xs font-bold uppercase tracking-[0.4em] text-black/40">04 / Prototyping Journey</h3>
                <div class="space-y-24">
                  <div class="space-y-8 text-center">
                    <img src={bridgeAssets.lowFi} alt="Low-Fi Stage" class="w-full h-auto border border-black/5" />
                    <p class="text-xs uppercase tracking-widest opacity-40 font-bold">Stage 1: Low-Fidelity Exploration & Layout Mapping</p>
                    <p class="mt-4 text-sm text-black/50 leading-relaxed max-w-xl mx-auto">
                      Early-stage wireframes focused on structural layout and navigation flow, establishing the foundational architecture of the communication platform.
                    </p>
                  </div>
                  <div class="space-y-8 text-center">
                    <img src={bridgeAssets.midFi} alt="Mid-Fi Stage" class="w-full h-auto border border-black/5" />
                    <p class="text-xs uppercase tracking-widest opacity-40 font-bold">Stage 2: Mid-Fidelity Interaction Design & Visual System</p>
                    <p class="mt-4 text-sm text-black/50 leading-relaxed max-w-xl mx-auto">
                      Transitioning into higher fidelity, incorporating the visual system and testing interactive elements to refine the user experience.
                    </p>
                  </div>
                </div>
              </div>

              <div class="pt-32 border-t border-black/5">
                <h3 class="text-xs font-bold uppercase tracking-[0.4em] text-black/40 mb-12 text-center">05 / The Final Solution</h3>
                <div class="bg-white border border-black/10 p-4 md:p-12 shadow-lg text-center">
                    <img src={bridgeAssets.highFi} alt="Final High-Fi Outcome" class="w-full h-auto mx-auto" />
                    <p class="mt-8 text-sm text-black/50 leading-relaxed max-w-xl mx-auto italic">
                      The final design solution addresses the identified friction points by introducing specialized interaction models that prioritize emotional support.
                    </p>
                </div>
              </div>
              
              <!-- Interactive Figma Prototype -->
              <div id="prototype" class="pt-48 border-t border-black/5 scroll-mt-32">
                <div class="text-center mb-24">
                  <h3 class="text-3xl md:text-5xl font-bold uppercase tracking-tighter mb-6">Interactive Prototype</h3>
                  <p class="text-lg text-black/60 max-w-2xl mx-auto leading-relaxed">
                    Test the high-fidelity flow directly in this mobile simulator. It captures the transition logic and micro-interactions of the final application.
                  </p>
                </div>
                
                <!-- REFINED MOBILE MOCKUP (75% Scale) -->
                <div class="relative max-w-lg mx-auto mb-32 text-center">
                  <!-- Phone Frame: Thinner bezels (p-2 md:p-3) -->
                  <div class="relative z-20 bg-black p-2 md:p-3 rounded-[4rem] shadow-[0_40px_80px_-15px_rgba(0,0,0,0.3)] border-[1px] border-white/10 overflow-hidden inline-block w-full">
                    <!-- Screen Container -->
                    <div class="relative w-full aspect-[9/19] overflow-hidden rounded-[3.5rem] bg-white">
                      <!-- Scaled Dynamic Island -->
                      <div class="absolute top-3 left-1/2 -translate-x-1/2 w-32 h-8 bg-black rounded-full z-30 pointer-events-none"></div>
                      
                      <iframe 
                        class="absolute inset-0 w-full h-full border-none scale-[1.20] origin-center"
                        src="https://www.figma.com/embed?embed_host=share&url=https%3A%2F%2Fwww.figma.com%2Fproto%2Fywb9PVuSmza6l1wdgvp04F%2FHigh-fidelity-prototype---The-Bridge%3Fnode-id%3D460-710%26starting-point-node-id%3D460%253A710%26t%3DD0hGgXYoLBFKIPs4-1&hide-ui=1" 
                        allowfullscreen
                      ></iframe>
                    </div>
                  </div>

                  <!-- Side Buttons (Refined) -->
                  <div class="absolute -left-1 top-24 w-1 h-12 bg-black/20 rounded-l-sm"></div>
                  <div class="absolute -left-1 top-40 w-1 h-16 bg-black/20 rounded-l-sm"></div>
                  <div class="absolute -left-1 top-60 w-1 h-16 bg-black/20 rounded-l-sm"></div>
                  <div class="absolute -right-1 top-44 w-1 h-24 bg-black/20 rounded-r-sm"></div>

                  <!-- Floor Shadow -->
                  <div class="absolute -bottom-10 left-1/2 -translate-x-1/2 w-4/5 h-10 bg-black/5 blur-2xl rounded-full -z-10"></div>
                </div>
              </div>
            </div>
          </details>
        </section>
      </div>
    )}

    {isMakersLoop && (
      <div class="space-y-64 pb-64">
        <section id="concept" class="grid grid-cols-12 gap-12 scroll-mt-32">
          <div class="col-span-12 md:col-span-4">
            <h2 class="text-xs font-black uppercase tracking-[0.4em] mb-8 sticky top-32">01 / Concept</h2>
          </div>
          <div class="col-span-12 md:col-span-8 space-y-16">
            <p class="text-xl md:text-2xl leading-loose text-black/70 font-medium max-w-4xl text-balance">
              The project is a modular pegboard system designed to serve as a material circular ecosystem for maker spaces. 
            </p>
            <div class="grid grid-cols-3 gap-6">
              {makersAssets.sketches.map((img) => (
                <div class="space-y-4">
                  <div class="aspect-square bg-black/5 overflow-hidden border border-black/5">
