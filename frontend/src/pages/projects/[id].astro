    {!isTheBridge && !isMakersLoop && !isRemindMe && !isMuseumOfGlass && (
      <section class="max-w-4xl mx-auto mb-48">
        <h2 class="text-2xl font-bold uppercase tracking-tight mb-12 border-b border-black pb-4">Project Overview</h2>
        <div class="prose prose-lg text-black/70 leading-relaxed italic">
          Content is currently being prepared for this project. Please check back later.
        </div>
      </section>
    )}
  </div>
</Layout>
