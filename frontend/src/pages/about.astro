---
import Layout from '../layouts/Layout.astro';

---

<Layout title="About | Eva Chen">
  <div class="max-w-7xl mx-auto px-6 pt-32 pb-24">
    <!-- About Hero Section -->
    <section class="grid grid-cols-1 md:grid-cols-12 gap-12 mb-32">
      <div class="md:col-span-8">
        <h1 class="text-7xl md:text-8xl font-bold uppercase tracking-tighter mb-12">
          I design for <br />
          <span class="text-[#66ccff]">Human Connection</span>.
        </h1>
      </div>
      <div class="md:col-span-4 flex flex-col justify-end">
        <div class="border-l-4 border-black pl-8 mb-4">
          <p class="text-xl italic font-medium opacity-60">
            "Design is not just what it looks like and feels like. Design is how it works."
          </p>
        </div>
      </div>
    </section>

    <!-- Content Section -->
    <section class="grid grid-cols-1 md:grid-cols-12 gap-16">
      <!-- Left Column: Image or Secondary Info -->
      <div class="md:col-span-5 space-y-12">
        <div class="aspect-[4/5] bg-black/5 flex items-center justify-center border border-black/5 overflow-hidden">
            <!-- You can add your profile picture here -->
            <span class="text-[10px] uppercase tracking-[0.5em] opacity-20">Profile Image Placeholder</span>
        </div>
        
        <div class="space-y-8">
            <div>
                <h3 class="text-sm font-bold uppercase tracking-[0.4em] mb-4">Current Focus</h3>
                <p class="text-lg text-black/60 leading-relaxed">
                    Researching accessibility in multi-lingual information systems at the University of Washington.
                </p>
            </div>
            <div>
                <h3 class="text-sm font-bold uppercase tracking-[0.4em] mb-4">Interests</h3>
                <ul class="text-lg text-black/60 leading-relaxed space-y-2">
                    <li>&rarr; 3D Prototyping</li>
                    <li>&rarr; Information Clarity</li>
                    <li>&rarr; Emotional Well-being</li>
                </ul>
            </div>
        </div>
      </div>

      <!-- Right Column: Main Text Content -->
      <div class="md:col-span-7">
        <div class="prose prose-xl prose-slate max-w-none">
          <h2 class="text-3xl font-bold uppercase tracking-tight mb-8">My Journey</h2>
          
          <div class="space-y-8 text-xl leading-relaxed text-black/80 font-medium">
            <p>
              Hi there, I’m Eva. I’m a human-centered designer, 3D prototyping enthusiast, and a firm believer that the best ideas exist off the screen. I love translating complex problems into tangible, accessible solutions—whether that means coding a new web app, designing a pop-up cafe experience, or prototyping with a 3D printer. Welcome to my workspace.
            </p>
            
            <p>
              I believe that the best design solutions often start from the most mundane frustrations. As a human-centered designer, I am passionate about taking complex problems and turning them into tangible experiences that everyone can understand and enjoy.
            </p>

            <p>
              Whether it is through code, physical prototypes, or visual storytelling, my goal is always to create a bridge between technology and human emotion.
            </p>
          </div>

          <div class="mt-20 pt-10 border-t border-black/5">
            <h3 class="text-sm font-bold uppercase tracking-[0.4em] mb-10">Experience & Education</h3>
            <div class="space-y-12">
                <div class="flex justify-between items-start group">
                    <div>
                        <h4 class="text-2xl font-bold uppercase italic group-hover:not-italic transition-all">University of Washington</h4>
                        <p class="text-black/60 uppercase tracking-widest text-sm mt-1">MS in Human Centered Design & Engineering</p>
                    </div>
                    <span class="font-bold opacity-20">2024 - Present</span>
                </div>
                <!-- Add more entries as needed -->
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>
