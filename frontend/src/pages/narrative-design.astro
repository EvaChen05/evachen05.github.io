---
import Layout from '../layouts/Layout.astro';

---

<Layout title="Narrative Design | Eva Chen">
  <div class="max-w-7xl mx-auto px-6 pt-32 pb-24">
    <!-- Hero Section -->
    <section class="mb-32">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-12 border-b border-black pb-12">
        <h1 class="text-7xl md:text-9xl font-bold uppercase tracking-tighter leading-none">
          Narrative <br />
          <span class="text-[#a855f7]">Design</span>
        </h1>
        <div class="max-w-md">
          <p class="text-xl font-medium opacity-60 leading-relaxed italic">
            "Every interaction is a story. I design the threads that weave them together into a meaningful experience."
          </p>
        </div>
      </div>
    </section>

    <!-- Narrative Content -->
    <section class="grid grid-cols-1 md:grid-cols-12 gap-16">
      <div class="md:col-span-4">
        <div class="sticky top-32 space-y-12">
            <div>
                <h3 class="text-sm font-bold uppercase tracking-[0.4em] mb-6">Philosophy</h3>
                <p class="text-lg text-black/60 leading-relaxed">
                    Narrative design goes beyond words; it’s about the emotional arc of a user journey, the rhythm of interaction, and the world-building within a digital or physical space.
                </p>
            </div>
            <div>
                <h3 class="text-sm font-bold uppercase tracking-[0.4em] mb-6">Methods</h3>
                <ul class="text-lg text-black/60 leading-relaxed space-y-3">
                    <li>&rarr; Experience Mapping</li>
                    <li>&rarr; World Building</li>
                    <li>&rarr; Emotional Archetyping</li>
                    <li>&rarr; Interactive Storytelling</li>
                </ul>
            </div>
        </div>
      </div>

      <div class="md:col-span-8">
        <div class="space-y-32">
            <!-- Content Block 1 -->
            <div class="space-y-8">
                <div class="aspect-video bg-black/5 flex items-center justify-center border border-black/5">
                    <span class="text-[10px] uppercase tracking-[0.5em] opacity-20">Narrative Project Case 01</span>
                </div>
                <div class="max-w-2xl">
                    <h2 class="text-3xl font-bold uppercase tracking-tight mb-4">Project Title</h2>
                    <p class="text-xl text-black/80 leading-relaxed">
                        [在此开始编写您的内容 / Start writing your story here...]
                    </p>
                </div>
            </div>

            <!-- Content Block 2 -->
            <div class="space-y-8">
                <div class="aspect-video bg-black/5 flex items-center justify-center border border-black/5">
                    <span class="text-[10px] uppercase tracking-[0.5em] opacity-20">Narrative Project Case 02</span>
                </div>
                <div class="max-w-2xl">
                    <h2 class="text-3xl font-bold uppercase tracking-tight mb-4">Designing the Arc</h2>
                    <p class="text-xl text-black/80 leading-relaxed">
                        Explore how storytelling principles can be applied to technical systems to create more intuitive and human-centered results.
                    </p>
                </div>
            </div>
        </div>
      </div>
    </section>
  </div>
</Layout>
