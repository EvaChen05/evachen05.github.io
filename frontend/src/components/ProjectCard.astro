---
import type { Project } from '@data/projects';
import { localeText } from '@data/i18n';

interface Props {
  project: Project;
}

const { project } = Astro.props;
const textEn = localeText.en.project;
const textZh = localeText.zh.project;
---

<a 
  href={`/projects/${project.id}`}
  class="group relative border-t border-black/5 pt-12 pb-24 overflow-hidden block transition-colors hover:border-black/20"
>
  <!-- Sliding Showcase Banner (Background) -->
  <div 
    class="absolute inset-y-0 left-0 w-full z-0 pointer-events-none transform -translate-x-full group-hover:translate-x-0 transition-transform duration-[800ms] ease-[cubic-bezier(0.16,1,0.3,1)] overflow-hidden"
  >
    <div class="relative w-full h-full">
      <img 
        src={project.thumbnail} 
        alt="" 
        class="w-full h-full object-cover grayscale opacity-30 scale-110 group-hover:scale-100 transition-transform duration-[1200ms] ease-out"
      />
      <!-- Gradient fade-out to keep edges clean -->
      <div class="absolute inset-0 bg-gradient-to-r from-transparent via-transparent to-paper"></div>
    </div>
  </div>

  <!-- Content Layer -->
  <div class="relative z-10 flex flex-col md:flex-row gap-12 px-2">
    <div class="md:w-1/4">
      <span class="text-[12px] font-bold uppercase tracking-[0.4em] text-black/40 mb-4 block group-hover:text-black transition-colors">
        <span class="lang-en">{textEn.caseStudy}</span>
        <span class="lang-zh">{textZh.caseStudy}</span>
      </span>
      <div class="flex flex-wrap gap-2">
        {project.tags.map((tag) => (
          <span class="lang-en text-[11px] uppercase tracking-widest font-semibold border border-black/20 px-3 py-1 bg-paper/50 backdrop-blur-sm group-hover:bg-white transition-colors">{tag}</span>
        ))}
        {project.zh.tags.map((tag) => (
          <span class="lang-zh text-[11px] uppercase tracking-widest font-semibold border border-black/20 px-3 py-1 bg-paper/50 backdrop-blur-sm group-hover:bg-white transition-colors">{tag}</span>
        ))}
      </div>
    </div>
    
    <div class="md:w-1/2">
      <h3 class="text-4xl font-bold uppercase tracking-tight mb-6 group-hover:italic transition-all duration-500">
        <span class="lang-en">{project.title}</span>
        <span class="lang-zh">{project.zh.title}</span>
      </h3>
      <p class="text-lg leading-relaxed text-black/60 max-w-xl group-hover:text-black transition-colors duration-500">
        <span class="lang-en-block">{project.description}</span>
        <span class="lang-zh-block">{project.zh.description}</span>
      </p>
    </div>

    <div class="md:w-1/4 flex items-end justify-end">
        <div class="text-[12px] font-bold uppercase tracking-widest border-b-2 border-black pb-1 group-hover:pb-3 transition-all duration-300">
            <span class="lang-en">{textEn.view} &rarr;</span>
            <span class="lang-zh">{textZh.view} &rarr;</span>
        </div>
    </div>
  </div>
</a>
